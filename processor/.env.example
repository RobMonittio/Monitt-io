# Copy this to .env and fill in your values
# Railway injects DATABASE_URL automatically — only needed for local dev

MQTT_HOST=caboose.proxy.rlwy.net
MQTT_PORT=52577
MQTT_USERNAME=monitt
MQTT_PASSWORD=your_mosquitto_password_here
MQTT_TOPIC=monitt/#

DATABASE_URL=postgresql://user:password@host:port/railway
